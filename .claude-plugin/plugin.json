{
  "name": "cortex",
  "version": "0.2.0",
  "description": "Local-first repo context engine for Claude Code. Provides graph-aware MCP tools, repository overview, impact analysis, symbol search, and refresh.",
  "author": {
    "name": "Alil Kuizon"
  },
  "keywords": [
    "context",
    "mcp",
    "code",
    "graph",
    "repository"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT:-${PLUGIN_ROOT:-.}}/hooks/session-start.py\"",
            "timeout": 5,
            "statusMessage": "Loading Cortex context..."
          }
        ]
      }
    ]
  }
}
