{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT:-${PLUGIN_ROOT:-.}}/hooks/session-start.py\"",
            "timeout": 5,
            "statusMessage": "Loading Cortex context..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT:-${PLUGIN_ROOT:-.}}/hooks/pre-tool-use.py\"",
            "timeout": 5,
            "statusMessage": "Checking Cortex indexed context..."
          }
        ]
      }
    ]
  }
}
